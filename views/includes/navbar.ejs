<style>

  .btn-search{

    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0rem 1rem 0rem 1rem;
  }

  .btn-search:hover{

    background-color: #fe424d;
    color: white;
  }

  .btn-search i{

    display:inline;
    margin-right: 0.4rem;
  }

  .input-search{

    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;

  }

/* Reduce search bar size at 767px and below */

@media (max-width: 767px) {

  .custom-navbar .custom-navbar-form {
    width: 50%;
    margin-top: 10px;
    min-width: 450px;
    margin-left: 0% !important; 
  }
}

@media (max-width: 480px) {

  .custom-navbar .custom-navbar-form {
    width: 50%;
    margin-top: 10px;
    min-width: 297px;
    margin-left: 0% !important; 
  }

  .custom-navbar-form .input-search{
    padding: 0;
    padding-left: 10px;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }
}



</style>

<nav class="navbar custom-navbar navbar-expand-md bg-body-light sticky-top border-bottom mb-2">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="fa-regular fa-compass"></i></a>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNavAltMarkup"
        aria-controls="navbarNavAltMarkup"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link" href="/listings">Explore</a>
        </div>
        <div class="navbar-nav custom-navbar-form ms-auto">
          <form class="d-flex" role="search">
            <input class="form-control me-2 input-search" type="search" 
            placeholder="Search destinations" aria-label="Search">
            <button class="btn btn-search" type="button">
              <i class="fa-solid fa-magnifying-glass"></i>Search
            </button>
          </form>
        </div>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/listings/new">AddNewListing</a>
          <% if(!currUser){%>
            <a class="nav-link" href="/signup">Signup</a>
            <a class="nav-link" href="/login">Login</a>
          <%}%>
          <% if(currUser){%>
            <a class="nav-link" href="/logout">Logout</a>
          <%}%>  
        </div>
      </div>
    </div>
  </nav>
